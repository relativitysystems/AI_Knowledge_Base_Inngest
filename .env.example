PORT=3000
NODE_ENV=development

# Supabase (server-side only — never expose service key to frontend)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Google Drive — MVP: service account
# Client shares a Drive folder with this service account email
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key with literal \n characters (or use a JSON key file path)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# API security — used by Relativity portal and internal scripts
API_KEY=

# Slack — MVP RAG bot interface
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
