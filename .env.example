PORT=3000
NODE_ENV=development

# Relativity - AIKB project (knowledge_documents, knowledge_chunks, knowledge_ingestion_jobs)
AIKB_SUPABASE_URL=
AIKB_SUPABASE_SERVICE_KEY=

# Relativity_Global project (master clients table)
GLOBAL_SUPABASE_URL=
GLOBAL_SUPABASE_SERVICE_KEY=

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Google Drive — MVP: service account
# Client shares a Drive folder with this service account email
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the private key with literal \n characters (or use a JSON key file path)
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# API security — used by Relativity portal and internal scripts
API_KEY=

# Slack — MVP RAG bot interface
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
